#!/usr/bin/env bash
# hawker-container - manage the dev container locally and on remote hosts
#
# Usage:
#   hawker-container <command> [args]
#
# Commands:
#   build                    Build the container image
#   run                      Build + load + run locally
#   push <host>              Build + push to remote host
#   enter [host]             Enter container (local or remote)
#   deploy <host>            Build + push + enter
#   status [host]            Check if container is running
#   stop [host]              Stop running container

set -euo pipefail

IMAGE_NAME="hawker-dev"

# Resolve symlink to find the actual repo (when run locally)
if [ -L "${BASH_SOURCE[0]}" ] || [ -f "${BASH_SOURCE[0]}" ]; then
    REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
    REPO_DIR="$(cd "$(dirname "$REAL_SCRIPT")/../../.." 2>/dev/null && pwd 2>/dev/null || echo "")"
fi
FLAKE_OUTPUT="container"

# ── Helpers ──

detect_runtime() {
    if command -v podman &>/dev/null; then
        echo podman
    elif command -v docker &>/dev/null; then
        echo docker
    else
        echo "Error: podman or docker required" >&2
        exit 1
    fi
}

detect_gpu_flags() {
    local runtime="$1"
    # Check if NVIDIA GPUs are available
    if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
        if [ "$runtime" = "docker" ]; then
            echo "--gpus all"
        else
            # Podman: use CDI if available, fall back to --device
            if [ -d "/etc/cdi" ] || [ -d "/var/run/cdi" ]; then
                echo "--device nvidia.com/gpu=all"
            else
                echo "--device /dev/nvidia0 --device /dev/nvidiactl --device /dev/nvidia-uvm --device /dev/nvidia-uvm-tools"
            fi
        fi
    fi
}

build() {
    echo "==> Building $IMAGE_NAME..."
    IMAGE_PATH=$(nix build "${REPO_DIR}#${FLAKE_OUTPUT}" --no-link --print-out-paths)
    echo "    $IMAGE_PATH"
}

push_to() {
    local host="$1"
    IMAGE_PATH=$(nix build "${REPO_DIR}#${FLAKE_OUTPUT}" --no-link --print-out-paths)
    echo "==> Pushing $IMAGE_NAME to $host..."
    rsync --progress --chmod=u+rw "$IMAGE_PATH" "${host}:${IMAGE_NAME}.tar.gz"
    rsync --chmod=u+rwx "$(readlink -f "${BASH_SOURCE[0]}")" "${host}:hawker-container"
    echo "==> Loading image on $host (this may take a minute)..."
    ssh "$host" "podman load -i ~/${IMAGE_NAME}.tar.gz 2>&1 || docker load -i ~/${IMAGE_NAME}.tar.gz 2>&1"
}

run_container() {
    local runtime
    runtime=$(detect_runtime)

    $runtime rm -f "$IMAGE_NAME" 2>/dev/null || true

    local mounts=()
    local env_args=(-e "TERM=xterm-256color")
    local extra_args=()

    # GPU passthrough
    local gpu_flags
    gpu_flags=$(detect_gpu_flags "$runtime")
    if [ -n "$gpu_flags" ]; then
        # shellcheck disable=SC2206
        extra_args+=($gpu_flags)
    fi

    # Forward SSH agent socket
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
        mounts+=(-v "$SSH_AUTH_SOCK:/tmp/ssh-agent.sock")
        env_args+=(-e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
    fi

    # Persistent work volume
    mounts+=(-v "${IMAGE_NAME}-work:/home/${HAWKER_USER:-$USER}/work")

    # Run project setup scripts on entry (idempotent -- each checks its own marker)
    local setup_cmd=""
    local projects="${HAWKER_PROJECTS:-}"
    if [ -n "$projects" ]; then
        for project in ${projects//,/ }; do
            local script="$HOME/hawker/containers/${project}-setup.sh"
            if [ -f "$script" ] 2>/dev/null; then
                setup_cmd+="bash ~/hawker/containers/${project}-setup.sh && "
            fi
        done
    fi

    exec $runtime run -it --rm \
        --name "$IMAGE_NAME" \
        --hostname "$IMAGE_NAME" \
        "${mounts[@]}" \
        "${env_args[@]}" \
        "${extra_args[@]}" \
        "$IMAGE_NAME:latest" \
        bash -c "${setup_cmd}exec fish"
}

# ── Commands ──

case "${1:-help}" in
    build)
        build
        ;;

    run)
        echo "==> Loading $IMAGE_NAME..."
        IMAGE_PATH=$(nix build "${REPO_DIR}#${FLAKE_OUTPUT}" --no-link --print-out-paths)
        $(detect_runtime) load -i "$IMAGE_PATH" 2>&1
        echo "==> Starting $IMAGE_NAME..."
        run_container
        ;;

    push|update)
        [ $# -lt 2 ] && echo "Usage: $0 push <host>" && exit 1
        build
        push_to "$2"
        echo "==> Done. Enter with: $0 enter $2"
        ;;

    enter)
        if [ $# -ge 2 ]; then
            ssh -A -tt "$2" "~/hawker-container run-local"
        else
            run_container
        fi
        ;;

    deploy)
        [ $# -lt 2 ] && echo "Usage: $0 deploy <host>" && exit 1
        build
        push_to "$2"
        echo "==> Entering container..."
        ssh -A -tt "$2" "~/hawker-container run-local"
        ;;

    run-local)
        run_container
        ;;

    status)
        if [ $# -ge 2 ]; then
            ssh "$2" "podman ps -f name=$IMAGE_NAME 2>/dev/null || docker ps -f name=$IMAGE_NAME 2>/dev/null"
        else
            podman ps -f "name=$IMAGE_NAME" 2>/dev/null || docker ps -f "name=$IMAGE_NAME" 2>/dev/null
        fi
        ;;

    stop)
        if [ $# -ge 2 ]; then
            ssh "$2" "podman stop $IMAGE_NAME 2>/dev/null || docker stop $IMAGE_NAME 2>/dev/null"
        else
            podman stop "$IMAGE_NAME" 2>/dev/null || docker stop "$IMAGE_NAME" 2>/dev/null
        fi
        ;;

    help|*)
        echo "hawker-container - manage dev containers"
        echo ""
        echo "Usage:"
        echo "  $0 build              Build container image"
        echo "  $0 run                Build + run locally"
        echo "  $0 push <host>        Build + push to remote"
        echo "  $0 enter [host]       Enter container (local or remote)"
        echo "  $0 deploy <host>      Build + push + enter"
        echo "  $0 status [host]      Check status"
        echo "  $0 stop [host]        Stop container"
        echo ""
        echo "Projects enabled (from settings.nix): \$HAWKER_PROJECTS"
        echo ""
        echo "Examples:"
        echo "  $0 run                              Run locally"
        echo "  $0 deploy ibm-kaiba                 Deploy to ibm-kaiba"
        echo "  $0 enter ibm-kaiba                  Enter on ibm-kaiba"
        ;;
esac
