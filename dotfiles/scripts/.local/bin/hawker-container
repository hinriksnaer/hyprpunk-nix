#!/usr/bin/env bash
# hawker-container - manage dev environments locally and on remote hosts
#
# Uses Nix natively when available (incremental deploys via nix copy),
# falls back to container streaming for hosts without Nix.
#
# Usage:
#   hawker-container <command> [args]
#
# Commands:
#   deploy <host>            Sync repo + Nix closure to remote, enter dev shell
#   enter [host]             Enter dev shell (local or remote)
#   push <host>              Sync repo + Nix closure without entering
#   status [host]            Check Nix availability on host
#
# Container fallback (for hosts without Nix):
#   container-deploy <host>  Build + stream container image + enter
#   container-run             Build + run container locally

set -euo pipefail

# Resolve symlink to find the actual repo
REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
REPO_DIR="$(cd "$(dirname "$REAL_SCRIPT")/../../.." 2>/dev/null && pwd 2>/dev/null || echo "")"

IMAGE_NAME="hawker-dev"
FLAKE_OUTPUT="container"
FLAKE_REF="${REPO_DIR}"

# ── Nix-native helpers ──

push_nix() {
    local host="$1"

    echo "==> Syncing repo to $host..."
    rsync -a --delete --exclude='.git' --chmod=Du+rwx,Fu+rw \
        "$REPO_DIR/" "${host}:~/hawker/"

    echo "==> Building dev shell..."
    nix build "${FLAKE_REF}#devShells.x86_64-linux.default" --no-link

    echo "==> Copying Nix closure to $host (only changed paths)..."
    nix copy --to "ssh://$host" "${FLAKE_REF}#devShells.x86_64-linux.default"
}

enter_remote() {
    local host="$1"
    ssh -A -tt "$host" "cd ~/hawker && nix develop --command fish"
}

enter_local() {
    cd "$REPO_DIR"
    exec nix develop --command fish
}

# ── Container fallback helpers ──

detect_runtime() {
    if command -v podman &>/dev/null; then
        echo podman
    elif command -v docker &>/dev/null; then
        echo docker
    else
        echo "Error: podman or docker required" >&2
        exit 1
    fi
}

detect_gpu_flags() {
    local runtime="$1"
    if command -v nvidia-smi &>/dev/null && nvidia-smi &>/dev/null; then
        if [ "$runtime" = "docker" ]; then
            echo "--gpus all"
        else
            if [ -d "/etc/cdi" ] || [ -d "/var/run/cdi" ]; then
                echo "--device nvidia.com/gpu=all"
            else
                echo "--device /dev/nvidia0 --device /dev/nvidiactl --device /dev/nvidia-uvm --device /dev/nvidia-uvm-tools"
            fi
        fi
    fi
}

container_push() {
    local host="$1"
    STREAM_SCRIPT=$(nix build "${REPO_DIR}#${FLAKE_OUTPUT}" --no-link --print-out-paths)
    rsync --chmod=u+rwx "$(readlink -f "${BASH_SOURCE[0]}")" "${host}:hawker-container"
    echo "==> Streaming $IMAGE_NAME to $host..."
    "$STREAM_SCRIPT" | ssh "$host" "podman load 2>&1 || docker load 2>&1"
}

container_run() {
    local runtime
    runtime=$(detect_runtime)

    $runtime rm -f "$IMAGE_NAME" 2>/dev/null || true

    local mounts=()
    local env_args=(-e "TERM=xterm-256color")
    local extra_args=()

    local gpu_flags
    gpu_flags=$(detect_gpu_flags "$runtime")
    if [ -n "$gpu_flags" ]; then
        # shellcheck disable=SC2206
        extra_args+=($gpu_flags)
    fi

    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
        mounts+=(-v "$SSH_AUTH_SOCK:/tmp/ssh-agent.sock")
        env_args+=(-e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
    fi

    mounts+=(-v "${IMAGE_NAME}-work:/home/${HAWKER_USER:-$USER}/work")

    local setup_cmd=""
    local projects="${HAWKER_PROJECTS:-}"
    if [ -n "$projects" ]; then
        for project in ${projects//,/ }; do
            setup_cmd+="if [ -f ~/hawker/containers/${project}-setup.sh ]; then bash ~/hawker/containers/${project}-setup.sh; fi && "
        done
    fi

    exec $runtime run -it --rm \
        --name "$IMAGE_NAME" \
        --hostname "$IMAGE_NAME" \
        "${mounts[@]}" \
        "${env_args[@]}" \
        "${extra_args[@]}" \
        "$IMAGE_NAME:latest" \
        bash -c "${setup_cmd}exec fish"
}

# ── Commands ──

case "${1:-help}" in
    deploy)
        [ $# -lt 2 ] && echo "Usage: $0 deploy <host>" && exit 1
        push_nix "$2"
        echo "==> Entering dev shell..."
        enter_remote "$2"
        ;;

    enter)
        if [ $# -ge 2 ]; then
            enter_remote "$2"
        else
            enter_local
        fi
        ;;

    push)
        [ $# -lt 2 ] && echo "Usage: $0 push <host>" && exit 1
        push_nix "$2"
        echo "==> Done. Enter with: $0 enter $2"
        ;;

    status)
        if [ $# -ge 2 ]; then
            echo "==> Checking $2..."
            ssh "$2" "nix --version 2>/dev/null && echo 'Nix: available' || echo 'Nix: not installed'"
            ssh "$2" "podman --version 2>/dev/null || docker --version 2>/dev/null || echo 'No container runtime'"
            ssh "$2" "nvidia-smi --query-gpu=gpu_name --format=csv,noheader 2>/dev/null || echo 'No GPUs detected'"
        else
            nix --version
            podman --version 2>/dev/null || docker --version 2>/dev/null || echo 'No container runtime'
            nvidia-smi --query-gpu=gpu_name --format=csv,noheader 2>/dev/null || echo 'No GPUs detected'
        fi
        ;;

    # ── Container fallback ──

    container-deploy)
        [ $# -lt 2 ] && echo "Usage: $0 container-deploy <host>" && exit 1
        container_push "$2"
        echo "==> Entering container..."
        ssh -A -tt "$2" "~/hawker-container container-run"
        ;;

    container-run)
        container_run
        ;;

    run-local)
        # Backwards compat: remote hosts may still have old hawker-container
        container_run
        ;;

    help|*)
        echo "hawker-container - manage dev environments"
        echo ""
        echo "Nix-native (preferred):"
        echo "  $0 deploy <host>          Sync + enter dev shell on remote"
        echo "  $0 enter [host]           Enter dev shell (local or remote)"
        echo "  $0 push <host>            Sync without entering"
        echo "  $0 status [host]          Check Nix/GPU availability"
        echo ""
        echo "Container fallback (hosts without Nix):"
        echo "  $0 container-deploy <host> Stream container image + enter"
        echo "  $0 container-run           Run container locally"
        echo ""
        echo "Examples:"
        echo "  $0 deploy ibm-kaiba       Deploy to ibm-kaiba via Nix"
        echo "  $0 enter ibm-kaiba        Enter existing dev shell"
        echo "  $0 enter                  Enter local dev shell"
        ;;
esac
