#!/usr/bin/env fish
# Set desktop theme using modular hook system
# Each stow package registers its theme integration via ~/.config/hyprpunk/theme-hooks.d/
# Usage: hyprpunk-theme-set-desktop <theme-name>

set script_dir (dirname (status -f))
set hooks_dir "$HOME/.config/hyprpunk/theme-hooks.d"

# Output helpers
set C_RESET '\033[0m'
set C_GREEN '\033[0;32m'
set C_BLUE '\033[0;34m'
set C_YELLOW '\033[0;33m'
set C_RED '\033[0;31m'

function info; echo -e "$C_BLUE→$C_RESET $argv"; end
function success; echo -e "$C_GREEN✓$C_RESET $argv"; end
function warning; echo -e "$C_YELLOW⚠$C_RESET $argv"; end
function error; echo -e "$C_RED✗$C_RESET $argv"; end

function box
    echo ""
    echo "╭────────────────────────────────────────╮"
    for line in (echo $argv[1] | string split \n)
        echo "│ $line"
    end
    echo "╰────────────────────────────────────────╯"
    echo ""
end

if test (count $argv) -lt 1
    echo "Usage: hyprpunk-theme-set-desktop <theme-name>"
    echo ""
    echo "Available themes:"
    $script_dir/hyprpunk-theme-list
    exit 1
end

# Find themes directory
if test -n "$HYPRPUNK_PATH"; and test -d "$HYPRPUNK_PATH/themes"
    set themes_dir "$HYPRPUNK_PATH/themes"
else
    set themes_dir "$HOME/.local/share/hyprpunk/themes"
end

# Normalize theme name
set theme_name (echo $argv[1] | string lower | string replace -a ' ' '-')

if not test -d "$themes_dir/$theme_name"
    error "Theme '$theme_name' does not exist"
    echo ""
    echo "Available themes:"
    $script_dir/hyprpunk-theme-list
    exit 1
end

set theme_path "$themes_dir/$theme_name"
set pretty_name (echo $theme_name | sed 's/-/ /g; s/\b\(.\)/\u\1/g')

box "Switching to theme: $pretty_name"

set applied_count 0
set skipped_count 0
set reload_names
set reload_commands

# Process hook files
if test -d "$hooks_dir"
    for hook_file in $hooks_dir/*
        set hook_name (basename $hook_file)
        set source_file ""
        set target_path ""
        set reload_cmd ""
        set hook_type "symlink"

        # Parse hook file
        for line in (cat $hook_file)
            set line (string trim $line)
            if test -z "$line"; or string match -q '#*' $line
                continue
            end
            set key (echo $line | string split '=' | head -1 | string trim)
            set val (echo $line | string replace "$key=" '' | string trim)
            switch $key
                case source
                    set source_file $val
                case target
                    set target_path (eval echo $val)
                case reload
                    set reload_cmd $val
                case type
                    set hook_type $val
            end
        end

        # Handle special types
        if test "$hook_type" = "hyprland"
            # Extract only variables + general{} block from theme's hyprland.conf
            if test -f "$theme_path/hyprland.conf"
                set active_theme_conf "$HOME/.config/hypr/active-theme.conf"
                printf '%s\n' \
                    '# Active Hyprland Theme (runtime-generated)' \
                    '# Managed by hyprpunk-theme-set-desktop' \
                    '' \
                    > $active_theme_conf
                grep '^\$' "$theme_path/hyprland.conf" >> $active_theme_conf 2>/dev/null
                sed -n '/^general {/,/^}/p' "$theme_path/hyprland.conf" >> $active_theme_conf 2>/dev/null
                set applied_count (math $applied_count + 1)
                success "Applied $hook_name theme"
            else
                set skipped_count (math $skipped_count + 1)
                warning "Skipped $hook_name (no hyprland.conf in theme)"
            end
            if test -n "$reload_cmd"
                set reload_names $reload_names "$hook_name"
                set reload_commands $reload_commands "$reload_cmd"
            end
            continue
        end

        # Standard symlink hook
        if test -n "$source_file"; and test -n "$target_path"
            if test -f "$theme_path/$source_file"
                mkdir -p (dirname $target_path) 2>/dev/null
                ln -sf "$theme_path/$source_file" "$target_path"
                set applied_count (math $applied_count + 1)
                success "Applied $hook_name"
            else
                set skipped_count (math $skipped_count + 1)
                warning "Skipped $hook_name ($source_file not in theme)"
            end
        end

        # Queue reload command
        if test -n "$reload_cmd"
            set reload_names $reload_names "$hook_name"
            set reload_commands $reload_commands "$reload_cmd"
        end
    end
else
    warning "No theme hooks found at $hooks_dir"
end

# Apply terminal themes (neovim, btop theme copy)
echo ""
info "Applying terminal themes"
set terminal_result ($script_dir/hyprpunk-theme-set-terminal $theme_name)
set terminal_counts (string split ":" $terminal_result)
set terminal_applied $terminal_counts[1]
set terminal_skipped $terminal_counts[2]
set applied_count (math $applied_count + $terminal_applied)
set skipped_count (math $skipped_count + $terminal_skipped)
success "Terminal themes applied"

# Set wallpaper
echo ""
info "Setting wallpaper"
$script_dir/hyprpunk-wallpaper-set $theme_name >/dev/null 2>&1
success "Setting wallpaper"

# Execute reload commands
echo ""
info "Reloading applications"
for i in (seq (count $reload_commands))
    set cmd $reload_commands[$i]
    set name $reload_names[$i]
    info "Reloading $name"
    eval $cmd >/dev/null 2>&1 &
    disown 2>/dev/null
    success "Reloaded $name"
end

# Send notification
notify-send "Theme Changed" "Switched to: $pretty_name" -t 3000 2>/dev/null
success "Sending notification"

# Summary
box "Theme switched to: $pretty_name

Applied: $applied_count  •  Skipped: $skipped_count"
